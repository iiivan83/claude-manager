# === Обязательные настройки ===

# Токен Telegram-бота (получить у @BotFather в Telegram)
TELEGRAM_BOT_TOKEN=

# Список Telegram-ID пользователей, которым разрешён доступ к боту
# Несколько ID через запятую: 123456789,987654321
ALLOWED_USER_IDS=

# === Необязательные настройки ===

# Папка проекта, с которой Claude будет работать по умолчанию
# CLAUDE_WORKING_DIR=/Users/you/your-project
