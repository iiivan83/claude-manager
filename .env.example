# === Обязательные настройки ===

# Токен Telegram-бота (получить у @BotFather в Telegram)
TELEGRAM_BOT_TOKEN=

# Список Telegram-ID пользователей, которым разрешён доступ к боту
# Несколько ID через запятую: 123456789,987654321
ALLOWED_USER_IDS=

# === Необязательные настройки ===

# Папка проекта, с которой Claude будет работать по умолчанию
# CLAUDE_WORKING_DIR=/Users/you/your-project

# Корневая папка для поиска проектов (используется командой /projects).
# Бот сканирует эту папку и показывает пользователю список подпапок как проекты.
# По умолчанию — /Users/ivan/Desktop/claude-sandbox
# PROJECTS_ROOT_DIR=/Users/you/all-your-projects

# === E2E тестирование (для автоматических тестов через Telethon) ===
# Telethon — библиотека, которая подключается к Telegram как обычный пользователь.
# Это нужно для E2E тестов: бот получает настоящие сообщения и отвечает на них.

# ID приложения — получить на https://my.telegram.org (раздел API development)
# TELETHON_API_ID=12345678

# Hash приложения — получить там же, на https://my.telegram.org
# TELETHON_API_HASH=abcdef1234567890abcdef1234567890

# Номер телефона для авторизации в Telegram (с кодом страны)
# TELETHON_PHONE=+79001234567

# Username бота, которому будут отправляться тестовые сообщения
# TELETHON_BOT_USERNAME=@my_claude_bot
