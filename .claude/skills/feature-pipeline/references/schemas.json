{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "orchestrator_log": {
      "type": "object",
      "description": "Мастер-лог всех операций пайплайна",
      "required": ["pipeline", "pipeline_name", "timestamp_start", "status", "scale", "rollbacks_count", "entries"],
      "properties": {
        "pipeline": { "type": "string", "const": "feature-pipeline" },
        "pipeline_name": { "type": "string", "description": "Название конкретного запуска" },
        "timestamp_start": { "type": "string", "format": "date-time" },
        "timestamp_end": { "type": ["string", "null"], "format": "date-time" },
        "status": { "type": "string", "enum": ["in_progress", "completed", "failed", "stopped"] },
        "scale": { "type": "string", "enum": ["small", "medium", "large"] },
        "rollbacks_count": { "type": "integer", "minimum": 0, "maximum": 2 },
        "entries": {
          "type": "array",
          "items": { "$ref": "#/definitions/log_entry" }
        }
      }
    },
    "log_entry": {
      "type": "object",
      "required": ["timestamp", "phase", "agent", "action", "details"],
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "phase": { "type": "string", "description": "Номер фазы: 0, 1, 2, ..., 10" },
        "agent": { "type": "string" },
        "action": { "type": "string", "enum": ["start", "complete", "fail", "rollback", "fix_cycle"] },
        "details": { "type": "string" },
        "output_file": { "type": "string" },
        "fix_cycle_attempt": { "type": "integer", "minimum": 0 },
        "duration_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "pipeline_state": {
      "type": "object",
      "description": "Состояние пайплайна для возобновления",
      "required": ["feature_name", "scale", "current_phase", "phases", "rollbacks_to_spec", "created_at", "updated_at"],
      "properties": {
        "feature_name": { "type": "string" },
        "scale": { "type": "string", "enum": ["small", "medium", "large"] },
        "current_phase": { "type": "number" },
        "phases": {
          "type": "object",
          "patternProperties": {
            "^[0-9]+(\\.[0-9]+)?$": {
              "type": "object",
              "required": ["status", "fix_cycles"],
              "properties": {
                "status": { "type": "string", "enum": ["pending", "in_progress", "completed", "failed", "skipped"] },
                "fix_cycles": { "type": "integer", "minimum": 0 }
              }
            }
          }
        },
        "rollbacks_to_spec": { "type": "integer", "minimum": 0, "maximum": 2 },
        "rollback_feedback": { "type": "array", "items": { "type": "string" } },
        "backup_branches": { "type": "array", "items": { "type": "string" } },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "agent_output_base": {
      "type": "object",
      "description": "Базовая структура выходного файла любого агента",
      "required": ["agent", "status", "timestamp", "result"],
      "properties": {
        "agent": { "type": "string" },
        "status": { "type": "string", "enum": ["success", "failed", "partial"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "result": { "type": "object" }
      }
    },
    "feature_intake_result": {
      "type": "object",
      "description": "Результат Фазы 0 — приём задачи",
      "required": ["task_title", "task_description", "goal", "expected_result", "scale", "scale_reasoning", "skipped_phases", "pipeline_log_dir"],
      "properties": {
        "task_title": { "type": "string" },
        "task_description": { "type": "string" },
        "goal": { "type": "string" },
        "expected_result": { "type": "string" },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "scale": { "type": "string", "enum": ["small", "medium", "large"] },
        "scale_reasoning": { "type": "string" },
        "skipped_phases": { "type": "array", "items": { "type": "string" } },
        "pipeline_log_dir": { "type": "string" }
      }
    },
    "impact_analysis_result": {
      "type": "object",
      "description": "Результат Фазы 1 — анализ влияния",
      "required": ["affected_files", "affected_functions", "affected_tests", "risk_zones"],
      "properties": {
        "affected_files": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "type", "reason"],
            "properties": {
              "path": { "type": "string" },
              "type": { "type": "string", "enum": ["modify", "create", "delete"] },
              "reason": { "type": "string" }
            }
          }
        },
        "affected_functions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["file", "function", "impact"],
            "properties": {
              "file": { "type": "string" },
              "function": { "type": "string" },
              "impact": { "type": "string" }
            }
          }
        },
        "affected_tests": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "action", "reason"],
            "properties": {
              "path": { "type": "string" },
              "action": { "type": "string", "enum": ["update", "delete", "keep"] },
              "reason": { "type": "string" }
            }
          }
        },
        "risk_zones": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["area", "risk_level", "reason"],
            "properties": {
              "area": { "type": "string" },
              "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
              "reason": { "type": "string" }
            }
          }
        },
        "spec_conflicts": { "type": "array", "items": { "type": "string" } },
        "new_tests_needed": { "type": "array", "items": { "type": "string" } }
      }
    },
    "feature_spec_result": {
      "type": "object",
      "description": "Результат Фазы 2 — спецификация изменений",
      "required": ["approach_summary", "changes"],
      "properties": {
        "approach_summary": { "type": "string" },
        "rollback_feedback_used": { "type": ["string", "null"] },
        "changes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["file", "type"],
            "properties": {
              "file": { "type": "string" },
              "type": { "type": "string", "enum": ["modify", "create", "delete"] },
              "diff_spec": {
                "type": "object",
                "properties": {
                  "was": { "type": "string" },
                  "becomes": { "type": "string" },
                  "reason": { "type": "string" }
                }
              },
              "full_spec": {
                "type": "object",
                "properties": {
                  "purpose": { "type": "string" },
                  "api": { "type": "array", "items": { "type": "string" } },
                  "algorithms": { "type": "string" },
                  "dependencies": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        }
      }
    },
    "test_plan_result": {
      "type": "object",
      "description": "Результат Фазы 3 — тест-план",
      "required": ["test_framework", "scale"],
      "properties": {
        "test_framework": { "type": "string" },
        "scale": { "type": "string", "enum": ["small", "medium", "large"] },
        "tests_to_update": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "changes"],
            "properties": {
              "path": { "type": "string" },
              "changes": { "type": "string" }
            }
          }
        },
        "tests_to_add": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "description", "level"],
            "properties": {
              "path": { "type": "string" },
              "description": { "type": "string" },
              "level": { "type": "string", "enum": ["unit", "integration", "e2e"] }
            }
          }
        },
        "tests_to_delete": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "reason"],
            "properties": {
              "path": { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        }
      }
    },
    "test_plan_review_result": {
      "type": "object",
      "description": "Результат Фазы 3.5 — верификация тест-плана",
      "required": ["verdict"],
      "properties": {
        "verdict": { "type": "string", "enum": ["approved", "rejected"] },
        "issues": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "description", "severity"],
            "properties": {
              "type": { "type": "string", "enum": ["missing_coverage", "redundant", "duplicate", "wrong_level"] },
              "description": { "type": "string" },
              "severity": { "type": "string", "enum": ["critical", "warning"] }
            }
          }
        },
        "approved_plan": {}
      }
    },
    "implementation_result": {
      "type": "object",
      "description": "Результат Фазы 4 — реализация",
      "required": ["changes_completed", "unit_tests_passed", "fix_cycles_used"],
      "properties": {
        "changes_completed": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["file", "type", "status"],
            "properties": {
              "file": { "type": "string" },
              "type": { "type": "string", "enum": ["modify", "create", "delete"] },
              "status": { "type": "string", "const": "done" }
            }
          }
        },
        "changes_failed": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["file", "reason", "attempts"],
            "properties": {
              "file": { "type": "string" },
              "reason": { "type": "string" },
              "attempts": { "type": "integer" }
            }
          }
        },
        "unit_tests_passed": { "type": "boolean" },
        "fix_cycles_used": { "type": "integer", "minimum": 0 }
      }
    },
    "test_result": {
      "type": "object",
      "description": "Общий результат тестовой фазы (5, 6, 7)",
      "required": ["total_tests", "passed", "failed", "skipped", "fix_cycles_used", "needs_rollback"],
      "properties": {
        "total_tests": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 },
        "failures": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["test", "error"],
            "properties": {
              "test": { "type": "string" },
              "error": { "type": "string" },
              "file": { "type": "string" },
              "modules": { "type": "array", "items": { "type": "string" } },
              "scenario": { "type": "string" }
            }
          }
        },
        "fix_cycles_used": { "type": "integer", "minimum": 0 },
        "needs_rollback": { "type": "boolean" }
      }
    },
    "review_result": {
      "type": "object",
      "description": "Результат Фазы 8 — ревью",
      "required": ["passes", "total_issues_found", "total_issues_fixed", "fix_cycles_used", "needs_rollback"],
      "properties": {
        "passes": {
          "type": "object",
          "required": ["quality", "security", "architecture", "spec_compliance", "regression"],
          "properties": {
            "quality": { "$ref": "#/definitions/review_pass" },
            "security": { "$ref": "#/definitions/review_pass" },
            "architecture": { "$ref": "#/definitions/review_pass" },
            "spec_compliance": { "$ref": "#/definitions/review_pass" },
            "regression": { "$ref": "#/definitions/review_pass" }
          }
        },
        "total_issues_found": { "type": "integer", "minimum": 0 },
        "total_issues_fixed": { "type": "integer", "minimum": 0 },
        "fix_cycles_used": { "type": "integer", "minimum": 0 },
        "needs_rollback": { "type": "boolean" }
      }
    },
    "review_pass": {
      "type": "object",
      "required": ["issues", "status"],
      "properties": {
        "issues": { "type": "array", "items": { "$ref": "#/definitions/review_issue" } },
        "status": { "type": "string", "enum": ["clean", "has_issues"] }
      }
    },
    "review_issue": {
      "type": "object",
      "required": ["severity", "description"],
      "properties": {
        "file": { "type": "string" },
        "line": { "type": "integer" },
        "severity": { "type": "string", "enum": ["critical", "warning", "info"] },
        "type": { "type": "string" },
        "description": { "type": "string" },
        "suggestion": { "type": "string" },
        "spec_item": { "type": "string" },
        "affected_module": { "type": "string" }
      }
    },
    "docs_result": {
      "type": "object",
      "description": "Результат Фазы 9 — документация",
      "required": ["documents_created", "documents_skipped"],
      "properties": {
        "documents_created": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "path", "action"],
            "properties": {
              "type": { "type": "string", "enum": ["changelog", "adr", "claude_md", "brd", "docs_index"] },
              "path": { "type": "string" },
              "action": { "type": "string", "enum": ["created", "updated"] }
            }
          }
        },
        "documents_skipped": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "reason"],
            "properties": {
              "type": { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        }
      }
    },
    "finalizer_result": {
      "type": "object",
      "description": "Результат Фазы 10 — финальная проверка",
      "required": ["final_test_run", "final_review", "fix_cycles_used", "needs_rollback"],
      "properties": {
        "final_test_run": {
          "type": "object",
          "required": ["passed"],
          "properties": {
            "passed": { "type": "boolean" },
            "details": { "type": "string" }
          }
        },
        "final_review": {
          "type": "object",
          "required": ["passed"],
          "properties": {
            "passed": { "type": "boolean" },
            "details": { "type": "string" }
          }
        },
        "commit_hash": { "type": "string" },
        "commit_message": { "type": "string" },
        "session_report": { "type": "string" },
        "fix_cycles_used": { "type": "integer", "minimum": 0 },
        "needs_rollback": { "type": "boolean" }
      }
    }
  }
}
