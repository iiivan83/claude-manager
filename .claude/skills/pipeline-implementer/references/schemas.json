{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "JSON-схемы всех структур данных скилла pipeline-implementer",
  "definitions": {
    "orchestrator_log": {
      "description": "Главный лог оркестратора — журнал всех шагов пайплайна",
      "type": "object",
      "required": ["pipeline", "created_at", "skill_name", "spec_file", "steps"],
      "properties": {
        "pipeline": { "type": "string", "const": "pipeline-implementer" },
        "created_at": { "type": "string", "format": "date-time" },
        "skill_name": { "type": "string", "description": "Название создаваемого скилла" },
        "spec_file": { "type": "string", "description": "Путь к исходной спецификации" },
        "resumed_from_step": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "null" }
          ],
          "description": "С какого шага продолжили (null если первый запуск)"
        },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/definitions/orchestrator_step" }
        }
      }
    },

    "orchestrator_step": {
      "description": "Одна запись в логе оркестратора — результат одного шага",
      "type": "object",
      "required": ["step_number", "start_time", "end_time", "agent", "success"],
      "properties": {
        "step_number": { "type": "integer", "minimum": 0 },
        "start_time": { "type": "string", "format": "date-time" },
        "end_time": { "type": "string", "format": "date-time" },
        "agent": { "type": "string", "description": "Имя агента или скрипта" },
        "input": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Пути к входным файлам"
        },
        "success": { "type": "boolean" },
        "comment": { "type": "string", "default": "" },
        "output": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Пути к файлам результатов"
        },
        "next_agent": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        }
      }
    },

    "agent_output_base": {
      "description": "Базовый формат результата любого агента",
      "type": "object",
      "required": ["agent", "pipeline", "called_by", "timestamp", "status"],
      "properties": {
        "agent": { "type": "string" },
        "pipeline": { "type": "string" },
        "called_by": { "type": "string", "default": "orchestrator" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": {
          "type": "string",
          "enum": ["success", "partial", "failed"]
        },
        "input": {
          "type": "object",
          "properties": {
            "description": { "type": "string" },
            "files": { "type": "array", "items": { "type": "string" } }
          }
        },
        "created_files": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "description"],
            "properties": {
              "path": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "result": { "type": "object" },
        "next_agent": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        }
      }
    },

    "spec_parser_result": {
      "description": "Результат работы агента spec-parser (Этап 1)",
      "allOf": [
        { "$ref": "#/definitions/agent_output_base" },
        {
          "type": "object",
          "properties": {
            "result": {
              "type": "object",
              "required": ["pipeline_name", "stages", "dependency_graph", "agent_prompts"],
              "properties": {
                "pipeline_name": { "type": "string" },
                "goal": { "type": "string" },
                "input_format": { "type": "string" },
                "output_format": { "type": "string" },
                "principles": { "type": "array", "items": { "type": "string" } },
                "stages": {
                  "type": "array",
                  "items": { "$ref": "#/definitions/stage_description" }
                },
                "dependency_graph": { "$ref": "#/definitions/dependency_graph" },
                "agent_prompts": {
                  "type": "array",
                  "items": { "$ref": "#/definitions/agent_prompt" }
                },
                "checklist_items": { "type": "array", "items": { "type": "string" } },
                "skills": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": { "type": "string" },
                      "description": { "type": "string" }
                    }
                  }
                },
                "logging": {
                  "type": "object",
                  "properties": {
                    "orchestrator_log_format": { "type": "string" },
                    "agent_output_format": { "type": "string" }
                  }
                },
                "testing": {
                  "type": "object",
                  "properties": {
                    "test_phases": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "phase_number": { "type": "integer" },
                          "name": { "type": "string" },
                          "type": { "type": "string" },
                          "description": { "type": "string" }
                        }
                      }
                    },
                    "test_input": { "type": "string" }
                  }
                },
                "documentation_references": { "type": "array", "items": { "type": "string" } },
                "parsing_errors": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      ]
    },

    "stage_description": {
      "description": "Описание одного этапа пайплайна",
      "type": "object",
      "required": ["stage_number", "name", "type"],
      "properties": {
        "stage_number": { "type": "integer", "minimum": 0 },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["agent", "script", "mixed"] },
        "goal": { "type": "string" },
        "input": { "type": "string" },
        "output": { "type": "string" },
        "tool": { "type": "string" },
        "dependencies": { "type": "array", "items": { "type": "integer" } },
        "error_handling": { "type": "string" }
      }
    },

    "dependency_graph": {
      "description": "Карта зависимостей между этапами",
      "type": "object",
      "properties": {
        "parallel_groups": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "group": { "type": "integer" },
              "stages": { "type": "array", "items": { "type": "integer" } },
              "reason": { "type": "string" }
            }
          }
        },
        "sequential_chains": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "chain": { "type": "array", "items": { "type": "integer" } },
              "reason": { "type": "string" }
            }
          }
        }
      }
    },

    "agent_prompt": {
      "description": "Текст промпта для одного агента",
      "type": "object",
      "required": ["agent_name", "prompt_text", "target_file"],
      "properties": {
        "agent_name": { "type": "string" },
        "prompt_text": { "type": "string" },
        "target_file": { "type": "string" }
      }
    },

    "schema_generator_result": {
      "description": "Результат работы агента schema-generator (Этап 2)",
      "allOf": [
        { "$ref": "#/definitions/agent_output_base" },
        {
          "type": "object",
          "properties": {
            "result": {
              "type": "object",
              "properties": {
                "schemas_count": { "type": "integer" },
                "schema_names": { "type": "array", "items": { "type": "string" } },
                "warnings": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      ]
    },

    "stage_delegation_result": {
      "description": "Результат делегирования создания одного файла (Этап 3)",
      "allOf": [
        { "$ref": "#/definitions/agent_output_base" },
        {
          "type": "object",
          "properties": {
            "delegation": {
              "type": "object",
              "properties": {
                "target_skill": { "type": "string", "enum": ["skill-creator", "script-creator-pipeline"] },
                "delegated_via": { "type": "string" }
              }
            },
            "result": {
              "type": "object",
              "properties": {
                "stage_number": { "type": "integer" },
                "stage_name": { "type": "string" },
                "file_type": { "type": "string", "enum": ["agent", "script"] },
                "file_path": { "type": "string" },
                "delegation_successful": { "type": "boolean" },
                "post_check_passed": { "type": "boolean" },
                "lines_count": { "type": "integer" }
              }
            }
          }
        }
      ]
    },

    "skillmd_delegation_result": {
      "description": "Результат делегирования создания SKILL.md (Этап 4)",
      "allOf": [
        { "$ref": "#/definitions/agent_output_base" },
        {
          "type": "object",
          "properties": {
            "delegation": {
              "type": "object",
              "properties": {
                "target_skill": { "type": "string", "const": "skill-creator" },
                "delegated_via": { "type": "string" }
              }
            },
            "result": {
              "type": "object",
              "properties": {
                "skill_name": { "type": "string" },
                "delegation_successful": { "type": "boolean" },
                "post_check_passed": { "type": "boolean" },
                "supplemented_sections": { "type": "array", "items": { "type": "string" } },
                "stages_referenced": { "type": "integer" },
                "agents_referenced": { "type": "array", "items": { "type": "string" } },
                "scripts_referenced": { "type": "array", "items": { "type": "string" } },
                "missing_files": { "type": "array", "items": { "type": "string" } },
                "todo_stubs": { "type": "array", "items": { "type": "string" } },
                "yaml_frontmatter_valid": { "type": "boolean" },
                "evals_created": { "type": "boolean" }
              }
            }
          }
        }
      ]
    },

    "structural_validation_result": {
      "description": "Результат теста T1 — проверка файловой структуры",
      "type": "object",
      "required": ["test_name", "timestamp", "summary"],
      "properties": {
        "test_name": { "type": "string", "const": "structural-validation" },
        "timestamp": { "type": "string", "format": "date-time" },
        "critical_checks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "check": { "type": "string" },
              "status": { "type": "string", "enum": ["PASS", "FAIL"] },
              "details": { "type": "string" }
            }
          }
        },
        "non_critical_checks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "check": { "type": "string" },
              "status": { "type": "string", "enum": ["PASS", "FAIL"] },
              "details": { "type": "string" }
            }
          }
        },
        "summary": {
          "type": "object",
          "properties": {
            "critical_passed": { "type": "integer" },
            "critical_failed": { "type": "integer" },
            "warnings": { "type": "integer" },
            "status": { "type": "string", "enum": ["PASS", "FAIL"] }
          }
        }
      }
    },

    "contract_verification_result": {
      "description": "Результат теста T2 — проверка совместимости данных",
      "type": "object",
      "required": ["test_name", "timestamp", "summary"],
      "properties": {
        "test_name": { "type": "string", "const": "contract-verification" },
        "timestamp": { "type": "string", "format": "date-time" },
        "test_number": { "type": "integer", "const": 1 },
        "contracts_checked": { "type": "integer" },
        "issues": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "severity"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["type_mismatch", "missing_required_field", "schema_ref_broken", "format_inconsistency", "enum_mismatch"]
              },
              "stage_from": { "type": "string" },
              "stage_to": { "type": "string" },
              "field": { "type": "string" },
              "expected": { "type": "string" },
              "actual": { "type": "string" },
              "severity": { "type": "string", "enum": ["error", "warning"] }
            }
          }
        },
        "summary": {
          "type": "object",
          "properties": {
            "total_checks": { "type": "integer" },
            "errors": { "type": "integer" },
            "warnings": { "type": "integer" },
            "status": { "type": "string", "enum": ["PASS", "FAIL"] }
          }
        }
      }
    },

    "flow_self_test_result": {
      "description": "Результат теста TF — проверка логики управления",
      "type": "object",
      "required": ["test_name", "timestamp", "summary"],
      "properties": {
        "test_name": { "type": "string", "const": "flow-self-test" },
        "timestamp": { "type": "string", "format": "date-time" },
        "test_number": { "type": "integer", "const": 1 },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "check": { "type": "string" },
              "status": { "type": "string", "enum": ["PASS", "FAIL"] },
              "details": { "type": "string" }
            }
          }
        },
        "summary": {
          "type": "object",
          "properties": {
            "total_checks": { "type": "integer", "const": 5 },
            "passed": { "type": "integer" },
            "failed": { "type": "integer" },
            "status": { "type": "string", "enum": ["PASS", "FAIL"] }
          }
        }
      }
    },

    "dry_run_result": {
      "description": "Результат теста T3 — пробный запуск чистым Claude",
      "type": "object",
      "required": ["test_name", "timestamp", "summary"],
      "properties": {
        "test_name": { "type": "string", "const": "dry-run" },
        "timestamp": { "type": "string", "format": "date-time" },
        "test_number": { "type": "integer", "const": 1 },
        "questions_count": { "type": "integer" },
        "contradictions_count": { "type": "integer" },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "location": { "type": "string" },
              "severity": { "type": "string", "enum": ["blocking", "minor"] }
            }
          }
        },
        "contradictions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "location_a": { "type": "string" },
              "location_b": { "type": "string" },
              "severity": { "type": "string", "enum": ["blocking", "minor"] }
            }
          }
        },
        "missing_references": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "referenced_in": { "type": "string" },
              "missing_file": { "type": "string" }
            }
          }
        },
        "ambiguities": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "location": { "type": "string" },
              "possible_interpretations": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "artifacts_created": { "type": "array" },
        "quality_score": { "type": "string" },
        "summary": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "enum": ["PASS", "FAIL"] },
            "blocking_issues": { "type": "integer" },
            "minor_issues": { "type": "integer" }
          }
        }
      }
    },

    "completeness_metrics_result": {
      "description": "Результат теста T4 — метрики полноты скилла",
      "type": "object",
      "required": ["test_name", "timestamp", "summary"],
      "properties": {
        "test_name": { "type": "string", "const": "completeness-metrics" },
        "timestamp": { "type": "string", "format": "date-time" },
        "metrics": {
          "type": "object",
          "properties": {
            "stages_count": { "$ref": "#/definitions/metric_entry" },
            "agents_count": { "$ref": "#/definitions/metric_entry" },
            "scripts_count": { "$ref": "#/definitions/metric_entry" },
            "schemas_count": { "$ref": "#/definitions/metric_entry" },
            "skill_md_sections": { "$ref": "#/definitions/metric_entry" },
            "total_lines": { "$ref": "#/definitions/metric_entry" },
            "has_error_handling": { "$ref": "#/definitions/metric_entry" },
            "has_logging": { "$ref": "#/definitions/metric_entry" }
          }
        },
        "summary": {
          "type": "object",
          "properties": {
            "total_metrics": { "type": "integer", "const": 8 },
            "passed": { "type": "integer" },
            "failed": { "type": "integer" },
            "status": { "type": "string", "enum": ["PASS", "FAIL"] }
          }
        }
      }
    },

    "metric_entry": {
      "description": "Одна метрика с порогом и статусом",
      "type": "object",
      "required": ["value", "threshold", "status"],
      "properties": {
        "value": {},
        "threshold": { "type": "string" },
        "status": { "type": "string", "enum": ["PASS", "FAIL"] }
      }
    },

    "problem_trace": {
      "description": "Диагноз одной проблемы (Этап 6 — Problem Tracer)",
      "type": "object",
      "required": ["agent", "status", "result"],
      "properties": {
        "agent": { "type": "string", "const": "problem-tracer" },
        "pipeline": { "type": "string" },
        "called_by": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["success", "failed"] },
        "result": {
          "type": "object",
          "properties": {
            "traced_problem": {
              "type": "object",
              "required": ["source_test", "problem_type", "culprit_file", "suggested_fix"],
              "properties": {
                "source_test": { "type": "string" },
                "test_issue": { "type": "string" },
                "problem_type": { "type": "string", "enum": ["structural", "contract", "logic", "reference"] },
                "culprit_file": { "type": "string" },
                "culprit_agent": { "type": "string" },
                "root_cause": { "type": "string" },
                "suggested_fix": { "type": "string" }
              }
            }
          }
        },
        "next_agent": {
          "oneOf": [{ "type": "string" }, { "type": "null" }]
        }
      }
    },

    "change_fix_result": {
      "description": "Результат починки (Этап 6 — Change Fixer)",
      "allOf": [
        { "$ref": "#/definitions/agent_output_base" },
        {
          "type": "object",
          "properties": {
            "result": {
              "type": "object",
              "properties": {
                "fixed_problems": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "problem_id": { "type": "integer" },
                      "from_test": { "type": "string" },
                      "culprit_file": { "type": "string" },
                      "before": { "type": "string" },
                      "after": { "type": "string" },
                      "fix_description": { "type": "string" }
                    }
                  }
                },
                "conflicts": { "type": "array" },
                "total_fixed": { "type": "integer" },
                "total_conflicts": { "type": "integer" },
                "iteration": { "type": "integer" },
                "summary": { "type": "string" }
              }
            }
          }
        }
      ]
    },

    "effectiveness_eval_task": {
      "description": "Задание для проверки эффективности (Этап 7)",
      "type": "object",
      "required": ["id", "prompt_with_skill", "prompt_baseline", "criteria"],
      "properties": {
        "id": { "type": "string" },
        "source_test": { "type": "string" },
        "prompt_with_skill": { "type": "string" },
        "prompt_baseline": { "type": "string" },
        "expected_result": { "type": "string" },
        "criteria": {
          "type": "array",
          "minItems": 3,
          "maxItems": 5,
          "items": {
            "type": "object",
            "required": ["id", "description", "check_type"],
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" },
              "check_type": {
                "type": "string",
                "enum": ["file_exists", "content_contains", "format_matches", "count_equals", "custom"]
              }
            }
          }
        }
      }
    },

    "effectiveness_benchmark": {
      "description": "Сводная статистика бенчмарка эффективности (Этап 7)",
      "type": "object",
      "required": ["skill_name", "timestamp", "results"],
      "properties": {
        "skill_name": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "results": {
          "type": "object",
          "properties": {
            "with_skill": {
              "type": "object",
              "properties": {
                "pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
                "criteria_passed": { "type": "integer" },
                "criteria_total": { "type": "integer" }
              }
            },
            "baseline": {
              "type": "object",
              "properties": {
                "pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
                "criteria_passed": { "type": "integer" },
                "criteria_total": { "type": "integer" }
              }
            },
            "delta": { "type": "number" }
          }
        }
      }
    },

    "effectiveness_fix_plan": {
      "description": "План крупных изменений для повышения эффективности (Этап 7)",
      "type": "object",
      "required": ["agent", "status", "result"],
      "properties": {
        "agent": { "type": "string", "const": "effectiveness-planner" },
        "pipeline": { "type": "string" },
        "called_by": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["success", "failed"] },
        "result": {
          "type": "object",
          "properties": {
            "plan": {
              "type": "object",
              "properties": {
                "changes": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "file", "change_type", "description"],
                    "properties": {
                      "id": { "type": "string" },
                      "file": { "type": "string" },
                      "change_type": { "type": "string", "enum": ["minor", "moderate", "major"] },
                      "description": { "type": "string" },
                      "reason": { "type": "string" },
                      "target_criteria": { "type": "array", "items": { "type": "string" } },
                      "depends_on": { "type": "array", "items": { "type": "string" } }
                    }
                  }
                },
                "execution_order": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                },
